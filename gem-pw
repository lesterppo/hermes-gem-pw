#!/usr/bin/env python3
"""
gem-pw v4 — Self-contained Gemini Gem CLI. No external server needed.
Launches Chromium per call, uses persistent profile for session.

LOCALE NOTE (2026-07-15): Gemini's web UI renders in the account's
language. This tool is locale-agnostic: every UI-string selector tries the
Traditional Chinese (zh-TW) label first, then the English label, then a
language-neutral structural selector. Switching Gemini between English and
zh-TW (or vice versa) does NOT require changing this file.

Commands:
  gem-pw <id> "prompt"                  Single-turn chat
  gem-pw <id> -c sess.json "prompt"     Multi-turn (persists conversation)
  gem-pw --create "Name" "Instr"        Create Gem
    --knowledge-file <f>                  Attach file to Gem knowledge
    --knowledge-code <url>                Import GitHub repo to knowledge
    --knowledge-photo <img>               Attach photo to knowledge
    --knowledge-folder <dir>              Zip & upload folder as knowledge
    -m <model> [--thinking extended]      Set default model
  gem-pw --edit <id> [options]          Edit existing Gem
    --name <n>                            Rename Gem
    --instructions <text>                 Replace instructions
    --knowledge-file <f>                  Add file to knowledge
    --knowledge-code <url>                Import GitHub repo to knowledge
    --knowledge-photo <img>               Add photo to knowledge
    --knowledge-folder <dir>              Zip & upload folder as knowledge
    -m <model> [--thinking extended]      Change default model
  gem-pw --delete <id>                  Delete Gem
  gem-pw --upload <id> -f <file> "Q"   Upload file + ask
  gem-pw --collab <id> -f <file> "Instr"  Upload artifact + request surgical diff only (token-efficient)
  gem-pw --img <id> "description"       Generate image + download
  gem-pw --help                         This help
"""

import asyncio, base64, fcntl, json, os, re, signal, sys, time
from datetime import datetime
from pathlib import Path

try: signal.signal(signal.SIGPIPE, signal.SIG_DFL)
except: pass

PROFILE = str(Path.home() / ".gemini-cli" / "cr-profile")
# Profile-aware output dir: defaults under ~/.hermes/gem_pw_output, overridable
# via GEM_PW_OUTPUT_DIR so isolated HERMES_HOMEs don't collide on /tmp.
OUTPUT_DIR = Path(os.environ.get("GEM_PW_OUTPUT_DIR") or
                  str(Path.home() / ".hermes" / "gem_pw_output"))
OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
QUIET = False
JSON_OUT = False  # compact output: {"ok":true,"f":"...","s":1234,"t":1.2}  # set by -q flag for agent consumption

# Single-instance lock: gem-pw drives ONE headed Chromium profile. Two
# concurrent invocations collide and produce empty "Analyzing" responses. A
# PID lockfile makes the second invocation fail fast with a clear error.
# SELF-HEAL: if the file names a PID that is no longer alive, the lock is
# stale and we steal it (this happened during a tool-timeout that orphaned
# the holder — without this, every later call returns LOCKED forever).
_LOCK_PATH = Path.home() / ".hermes" / "gem_pw.lock"
_LOCK_FD = None


def _pid_alive(pid):
    try:
        os.kill(int(pid), 0)
        return True
    except (OSError, ValueError):
        return False


def _acquire_lock():
    global _LOCK_FD
    if _LOCK_FD is not None:
        return True
    try:
        # Steal/reclaim a stale lock before opening.
        stale = None
        if _LOCK_PATH.exists():
            try:
                old = _LOCK_PATH.read_text().strip()
                if old and not _pid_alive(old):
                    stale = old
            except Exception:
                pass
        if stale is not None:
            try:
                _LOCK_PATH.unlink()
                _log(f"reclaimed stale lock from dead pid {stale}")
            except Exception:
                pass
        _LOCK_FD = open(_LOCK_PATH, "w")
        fcntl.flock(_LOCK_FD, fcntl.LOCK_EX | fcntl.LOCK_NB)
        _LOCK_FD.write(str(os.getpid()))
        _LOCK_FD.flush()
        # Keep the fd open; also register a release on normal exit.
        import atexit
        atexit.register(_release_lock)
        return True
    except OSError:
        _release_lock()
        return False
    except Exception:
        _release_lock()
        return False


def _release_lock():
    global _LOCK_FD
    if _LOCK_FD is None:
        return
    try:
        fcntl.flock(_LOCK_FD, fcntl.LOCK_UN)
    except Exception:
        pass
    try:
        _LOCK_FD.close()
    except Exception:
        pass
    _LOCK_FD = None
    try:
        _LOCK_PATH.unlink(missing_ok=True)
    except Exception:
        pass

# Transient errors worth retrying with a fresh Chromium launch + resubmit.
# Each is a state where the UI wasn't ready / a hiccup occurred, not a
# permanent selector breakage (those would loop uselessly and waste ~3 min).
#   EMPTY        — response came back empty (Gem UI hiccup / placeholder lock)
#   NO_INPUT     — chat input not found (page still rendering)
#   NO_UPLOAD    — file picker didn't appear (drawer still animating)
#   NO_NAME_INPUT / NO_INST_INPUT — create/edit form not ready
#   NOT_SIGNED_IN — transient sign-in flicker; retry, else actionable msg
#   TRANSIENT_TIMEOUT — a Playwright TimeoutError escaped a cmd (UI not ready)
#   TYPE_FAILED  — compose text didn't land in the prompt box; resubmit on a
#                  fresh page (previously, unconfirmed text was submitted blindly,
#                  which produced empty/confused Gem responses during long codegen)
_TRANSIENT = {"EMPTY", "NO_INPUT", "NO_UPLOAD", "NO_NAME_INPUT", "NO_INST_INPUT",
              "NOT_SIGNED_IN", "TRANSIENT_TIMEOUT", "TYPE_FAILED"}
_MAX_ATTEMPTS = 3

def _emit(d):
    """Print a JSON result, compacting verbose fields when JSON_OUT is set."""
    if JSON_OUT:
        d = {k: v for k, v in d.items() if k not in ("msg", "accounts", "note")}
    print(json.dumps(d, ensure_ascii=False))


def _log(msg):
    if QUIET: return
    ts = datetime.now().strftime("%H:%M:%S")
    os.write(2, f"[pw {ts}] {msg}\n".encode())

def _err(code, msg, **extra):
    d = {"ok": False, "err": code, "msg": msg}; d.update(extra); return d


async def _retry_once(coro_factory):
    """Run an async command; on a transient error (returned dict OR raised
    exception), retry with a fresh Chromium launch up to _MAX_ATTEMPTS times.
    Returns the final dict (never raises, so the agent always gets JSON).

    Error-specific handling:
      * NOT_SIGNED_IN — retry once (transient sign-in flicker); if it persists,
        enrich the message with an actionable re-auth hint instead of looping.
      * Others (EMPTY/NO_INPUT/NO_UPLOAD/NO_NAME_INPUT/NO_INST_INPUT, or a
        raised Playwright TimeoutError) — retry once (UI not ready).
    A hard cap prevents useless ~3-min loops on genuinely broken selectors.
    """
    _TRANSIENT_EXC = {"TimeoutError", "Error"}  # Playwright raises these
    async def _run():
        try:
            return await coro_factory()
        except Exception as e:
            name = type(e).__name__
            if name in _TRANSIENT_EXC:
                return {"ok": False, "err": "TRANSIENT_TIMEOUT",
                        "msg": f"{name}: {str(e)[:160]}"}
            raise
    res = await _run()
    attempts = 1
    while (isinstance(res, dict) and res.get("ok") is False
           and res.get("err") in _TRANSIENT and attempts < _MAX_ATTEMPTS):
        _log(f"transient error {res.get('err')}; retry {attempts}/{_MAX_ATTEMPTS - 1}...")
        await asyncio.sleep(2)
        res = await _run()
        attempts += 1
    if isinstance(res, dict) and res.get("err") == "NOT_SIGNED_IN":
        res = {**res, "msg": res.get("msg", "") + " — re-authenticate by running the gem-pw "
               "login flow (or start cr-server with `cr-server login`), then retry."}
    return res


async def _verify_save(page):
    """Click Save/Update and VERIFY it registered. Returns (saved_bool, detail).
    Unlike _click_text_button (which returns None on miss with no error), this
    fails loudly so a Gem is never silently left un-saved."""
    clicked = await _click_text_button(page, ["儲存", "Save", "更新", "Update"])
    if not clicked:
        return False, "save-button-not-found"
    await asyncio.sleep(5)
    # After save, Gemini usually navigates to /gems/view or shows a toast.
    # A reliable signal: the save button is gone / URL changed away from /edit/.
    saved_ok = await page.evaluate("""() => {
        const on_edit = /\\/edit\\//.test(location.href);
        const still_has_save = [...document.querySelectorAll('button')].some(b => {
            const t = (b.innerText||'').trim();
            return (t === '儲存' || t === 'Save' || t === '更新' || t === 'Update') && b.offsetParent;
        });
        return !on_edit || !still_has_save;
    }""")
    return bool(saved_ok), ("ok" if saved_ok else "save-button-still-present")

def _ok(**kw): d = {"ok": True}; d.update(kw); return d


# ───────────────────── LOCALE-AGNOSTIC SELECTORS ─────────────────────
# Each helper tries candidate matchers in order and returns the first hit.
# A matcher is either a CSS selector string (tried via query_selector) or a
# callable taking `page` and returning an element handle / truthy.

async def _pick(page, matchers):
    """Return first non-None element handle across `matchers`.
    matchers: list of CSS selector strings, or (css, js_text_check) tuples,
    or async callables returning an element or None."""
    for m in matchers:
        try:
            if callable(m):
                el = await m(page)
            elif isinstance(m, tuple):
                css, js = m
                el = await page.query_selector(css)
                if el and js:
                    ok = await page.evaluate(js, el)
                    if not ok: el = None
            else:
                el = await page.query_selector(m)
            if el:
                return el
        except Exception:
            pass
    return None

async def _pick_text_button(page, labels):
    """Find a <button> whose visible text equals (trimmed) one of `labels`.
    Uses evaluate_handle so we get a real Playwright ElementHandle back
    (plain page.evaluate serializes DOM nodes to non-clickable values)."""
    labels_l = [l.lower() for l in labels]
    js = "(labels) => { const bs=[...document.querySelectorAll('button')];" \
         " for (const b of bs){ const t=(b.innerText||'').trim().toLowerCase();" \
         " if (labels.includes(t) && b.offsetParent) return b; } return null; }"
    try:
        return await page.evaluate_handle(js, labels_l)
    except Exception:
        return None

async def _click_text_button(page, labels):
    b = await _pick_text_button(page, labels)
    if b:
        try:
            await b.click(); await asyncio.sleep(1)
            return True
        except Exception:
            return False
    return False


# CDP reuse: prefer connecting to an already-running headed Chromium page
# server (e.g. hermes_cdp_server.py on 9223) for reliability + token savings
# (warm browser, no cold-start races, persistent tab enables true multi-turn).
# Fall back to launching our own headed Chromium if CDP is unavailable.
CDP_URL = os.environ.get("GEM_PW_CDP", "http://127.0.0.1:9223")
_SESSION_MODE = "headed"  # set to "cdp" when we connect via CDP

def _cdp_alive(url=CDP_URL, timeout=3.0):
    """True if a CDP server answers /json/version (liveness check)."""
    try:
        import urllib.request
        req = urllib.request.Request(url.rstrip("/") + "/json/version")
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return r.status == 200
    except Exception:
        return False

async def _launch(cdp=None):
    """Launch or connect to Chromium. Returns (pw, ctx, page).

    Priority:
      1. If `cdp` is explicitly set (URL or True), or GEM_PW_CDP is set and
         the server is alive, connect to it via connect_over_cdp (warm, reuse).
      2. Otherwise launch our own headed Chromium (self-contained fallback).
    In CDP mode the returned `page` is a fresh tab on the shared browser; the
    caller must NOT close the browser — use _close_session() which only closes
    the page in CDP mode.
    """
    global _SESSION_MODE
    use_cdp = bool(cdp) or (CDP_URL and _cdp_alive())
    if use_cdp:
        try:
            from playwright.async_api import async_playwright, Error as PwError
            pw = await async_playwright().start()
            browser = await pw.chromium.connect_over_cdp(CDP_URL)
            # Reuse the server's default context (carries the signed-in profile).
            ctx = browser.contexts[0] if browser.contexts else await browser.new_context()
            page = await ctx.new_page()
            page.set_default_timeout(180000)
            _SESSION_MODE = "cdp"
            _log(f"connected via CDP ({CDP_URL})")
            await _reset_page(page)  # clear any stale modal/composer on the shared tab
            return pw, ctx, page
        except Exception as e:
            _log(f"CDP connect failed ({e}); falling back to headed launch")
            use_cdp = False
    # Fallback: own headed Chromium.
    from playwright.async_api import async_playwright, Error as PwError
    # Clean stale profile locks from previous killed sessions
    for lock in ["SingletonLock", "SingletonCookie", "SingletonSocket"]:
        lp = Path(PROFILE) / lock
        if lp.exists():
            try: lp.unlink()
            except: pass
    pw = await async_playwright().start()
    for attempt in range(3):
        try:
            ctx = await pw.chromium.launch_persistent_context(
                user_data_dir=PROFILE, headless=False,
                args=['--no-sandbox','--disable-gpu','--disable-blink-features=AutomationControlled',
                      '--remote-debugging-port=0'],
                ignore_default_args=['--enable-automation'])
            page = await ctx.new_page()
            page.set_default_timeout(180000)
            _SESSION_MODE = "headed"
            return pw, ctx, page
        except PwError as e:
            if attempt < 2:
                _log(f"launch retry {attempt+1}: {e}")
                await asyncio.sleep(2)
            else:
                raise
    raise RuntimeError("Failed to launch")

async def _close_session(pw, ctx, page):
    """Close only what we own. In CDP mode the browser is shared (the server's),
    so we must NOT stop it — just close the page we opened. In headed mode we
    tear down the whole context + playwright."""
    global _SESSION_MODE
    try:
        if page: await page.close()
    except Exception:
        pass
    if _SESSION_MODE == "cdp":
        # Leave the shared browser alive for the next call.
        try: await pw.stop()
        except Exception: pass
        return
    try: await ctx.close()
    except Exception: pass
    try: await pw.stop()
    except Exception: pass

async def _reset_page(page):
    """Per-call reset of the shared CDP tab: clear any leftover modal/composer
    state so a stale dialog from a prior call can't corrupt this one."""
    try:
        await page.goto("about:blank", wait_until="domcontentloaded", timeout=15000)
    except Exception:
        pass
    try:
        await page.keyboard.press("Escape"); await asyncio.sleep(0.3)
    except Exception:
        pass


async def _find_input(page, timeout=10):
    """Find chat input element. Retries for `timeout` seconds.
    Locale-agnostic: zh-TW '輸入提示', English 'Enter a prompt for Gemini',
    then structural fallbacks (rich-textarea / generic contenteditable)."""
    t0 = time.time()
    while time.time() - t0 < timeout:
        el = await _pick(page, [
            'div[role="textbox"][aria-label*="輸入提示"]',
            'div[role="textbox"][aria-label*="prompt" i]',
            'div[role="textbox"][aria-label*="Enter a prompt"]',
            'rich-textarea div[contenteditable="true"]',
            'div[contenteditable="true"]:not(.ql-clipboard)',
        ])
        if el: return el
        await asyncio.sleep(1)
    return None


async def _type_and_submit(page, text):
    el = await _find_input(page)
    if not el: return False
    # Dismiss any open "Upload & tools" drawer / menu so it can't intercept the
    # composer click (after a file upload the drawer often stays open and eats
    # the focus/click, leaving the prompt unsubmitted -> empty response).
    try:
        await page.keyboard.press("Escape"); await asyncio.sleep(0.4)
    except Exception:
        pass
    # Focus the contenteditable input. Use DOM focus + click for robustness.
    try:
        await el.focus(timeout=5000)
    except Exception:
        pass
    await el.click(); await asyncio.sleep(0.3)
    await page.keyboard.press("Control+a"); await asyncio.sleep(0.1)
    await page.keyboard.press("Backspace"); await asyncio.sleep(0.3)
    # Use insert_text: pastes the whole string via DOM events without waiting
    # on per-character element stability. This avoids the 180s ElementHandle.type
    # hang that occurs on restored (multi-turn) conversations where Gemini keeps
    # re-rendering the contenteditable. Long prompts are inserted in chunks.
    try:
        for i in range(0, len(text), 4000):
            await page.keyboard.insert_text(text[i:i+4000])
            await asyncio.sleep(0.15)
    except Exception as e:
        _log(f"insert_text failed ({e}); falling back to el.type")
        for i in range(0, len(text), 200):
            await el.type(text[i:i+200], delay=2)
    await asyncio.sleep(0.3)
    # Verify the text actually landed in the composer before submitting.
    # If it didn't, return False so the caller can retry with a fresh page
    # instead of submitting an empty/partial prompt (which produced empty or
    # confused Gem responses in the past).
    landed = False
    try:
        composer = await page.evaluate("""() => {
            const el = document.querySelector('div[contenteditable="true"][role="textbox"], rich-textarea div[contenteditable="true"]');
            return el ? (el.innerText || '').slice(-200) : '';
        }""")
        landed = text.strip()[-80:] in (composer or "")
    except Exception:
        landed = False  # can't verify → treat as failure, do NOT submit blindly
    if not landed:
        _log("WARNING: composer text not confirmed; NOT submitting (caller will retry)")
        return False
    await page.keyboard.press("Enter")
    return True


async def _wait_response(page, timeout=120):
    t0 = time.time(); resp = ""
    # Transient placeholder texts the Gem UI shows during thinking/streaming.
    # Treating these as a "final" answer causes premature termination (we saw
    # the guard lock onto "Analyzing" and emit a 9-char response). Never treat
    # these as a stable result.
    PLACEHOLDERS = ("analyzing", "generating", "thinking", "loading", "wait", "正在分析",
                    "產生中", "思考中", "分析中", "載入中")
    def _is_placeholder(t):
        s = (t or "").strip().lower()
        if not s: return True
        return any(p in s for p in PLACEHOLDERS) and len(s) < 40
    for i in range(timeout // 3):
        await asyncio.sleep(3)
        _log(f"poll {i+1}/{timeout//3}")
        try:
            t = await page.evaluate("""() => {
                const msgs = document.querySelectorAll('.response-content, message-content, model-response');
                return msgs.length ? msgs[msgs.length-1].innerText : '';
            }""")
            if t and len(t) > len(resp): resp = t
        except: pass
        # Check completion: response exists AND all loading indicators are gone
        if resp and not _is_placeholder(resp):
            try:
                loading = await page.evaluate("""() => {
                    const sel = '.loading, .generating, .dot-pulse, [aria-busy="true"], .progress-indicator, .response-loading, .stream-text';
                    return document.querySelectorAll(sel).length;
                }""")
                if loading == 0:
                    await asyncio.sleep(2)
                    try:
                        t = await page.evaluate("""() => {
                            const msgs = document.querySelectorAll('.response-content, message-content');
                            return msgs.length ? msgs[msgs.length-1].innerText : '';
                        }""")
                        if t: resp = t
                    except: pass
                    break
            except: pass
        # Timeout guard: if resp hasn't changed in 6 polls (18s) AND is not a
        # placeholder, it's probably done.
        if resp and not _is_placeholder(resp) and i >= 5:
            try:
                t = await page.evaluate("""() => {
                    const msgs = document.querySelectorAll('.response-content, message-content');
                    return msgs.length ? msgs[msgs.length-1].innerText : '';
                }""")
                if t and t == resp:  # unchanged for one cycle
                    await asyncio.sleep(1)
                    t2 = await page.evaluate("""() => {
                        const msgs = document.querySelectorAll('.response-content, message-content');
                        return msgs.length ? msgs[msgs.length-1].innerText : '';
                    }""")
                    if t2 == resp:  # unchanged for two cycles → done
                        _log("stable response, done")
                        break
            except: pass
    # If we exhausted all polls while the response is still a placeholder
    # (e.g. stuck on "Analyzing"/"Thinking"), do NOT return it as a success.
    # Return empty so the caller emits a retryable EMPTY error (re-submits the
    # prompt on a fresh page) instead of a false-positive ok with placeholder text.
    if _is_placeholder(resp):
        _log("timed out while response still a placeholder; treating as empty (retryable)")
        resp = ""
    return resp, time.time() - t0


def _save(text, prompt, elapsed, gem_id=None, conv_file=None, output_path=None):
    if output_path:
        out = Path(output_path)
    else:
        ts = int(time.time())
        out = OUTPUT_DIR / f"gem-pw-{ts}.md"
    out.write_text(text, encoding="utf-8")
    _log(f"{elapsed:.1f}s {len(text)}c → {out}")
    r = {"ok": True, "f": str(out), "s": len(text), "b": len(text.encode("utf-8")), "t": round(elapsed, 1)}
    if gem_id: r["gem"] = gem_id
    if conv_file: r["c"] = conv_file
    if JSON_OUT:
        return {"ok": True, "f": str(out), "s": len(text), "t": round(elapsed, 1)}
    return r


def _check_page(body):
    if "Sign in" in body[:400]: return "NOT_SIGNED_IN"
    if "404" in body[:200] or "not found" in body[:200].lower(): return "NOT_FOUND"
    return None


# Ported from gem.py: refuse to create/edit on the wrong account.
# A wrong/extra signed-in account silently downgrades Pro → Flash in Gemini,
# so we surface account count before touching the model picker. Detection scans
# innerText/title/aria-label across all elements (the email can live in various
# nodes). A CLEAR multi-account situation (>1) is a hard block; 0 is treated as
# "could not detect" (soft warning) because the email is not always in the DOM.
async def _check_accounts(page):
    """Return list of @gmail.com accounts visible on the page."""
    return await page.evaluate("""() => {
        const o = [];
        const regs = /^[\\w.+-]+@gmail\\.com$/;
        document.querySelectorAll('*').forEach(e => {
            const txt = (e.innerText || e.getAttribute('title') || e.getAttribute('aria-label') || '').trim();
            // only leaf-ish text nodes (avoid matching huge containers)
            if (regs.test(txt) && !o.includes(txt)) o.push(txt);
        });
        return o;
    }""")


# Locale-agnostic menuitem click: tries each candidate text substring.
# Finds the menuitem via a JS innerText scan, then clicks it at its center
# coordinates with page.mouse. This is the most reliable "trusted" click for
# Google's custom GEM-MENU-ITEM elements: a JS .click() switches Extended
# thinking but NOT the base model, while Playwright's element.click() hangs
# waiting for the element to stop re-rendering (never "stable").
async def _click_menuitem(page, candidates):
    """Click first [role=menuitem] whose innerText includes one of `candidates`."""
    for c in candidates:
        try:
            box = await page.evaluate("""(cand) => {
                const sel = '[role=menuitem],[role=option],[role=menuitemradio],[role=menuitemcheckbox]';
                const items = document.querySelectorAll(sel);
                for (const it of items) {
                    const t = (it.innerText || it.getAttribute('aria-label') || '').replace(/\\s+/g, ' ');
                    if (t.includes(cand) && it.offsetParent) {
                        const r = it.getBoundingClientRect();
                        return {x: r.x + r.width/2, y: r.y + r.height/2};
                    }
                }
                return null;
            }""", c)
            if box:
                await page.mouse.click(box["x"], box["y"])
                await asyncio.sleep(1)
                _log(f"menuitem: {c}")
                return c
        except Exception:
            pass
    return None


async def _select_model(page, model, thinking):
    """Click model selector and pick model + thinking tier, then VERIFY.
    Locale-agnostic: tries zh-TW '模式選擇器', English 'Open mode picker',
    then a Pro/Flash text button. Extended thinking: zh-TW '延伸思考' / EN
    'Extended thinking'.
    Borrowed from gem.py: Google's menu closes after each selection, so the
    Extended-thinking click must REOPEN the picker. We also read back the
    picker aria-label and retry (up to 4×) until both base model AND Extended
    are confirmed — silent downgrade to Flash or dropping thinking is caught."""
    MODEL_BTN = [
        'button[aria-label*="模式選擇器"]',
        'button[aria-label*="selector" i]',
        'button[aria-label*="model" i]',
        'button[aria-label*="mode" i]',
        'button[aria-label*="picker" i]',
        'button:has-text("Pro")',
        'button:has-text("Flash")',
    ]

    async def _picker_label():
        try:
            return await page.evaluate("""() => {
                const b = document.querySelector('button[aria-label*="模式選擇器"]')
                       || document.querySelector('button[aria-label*="picker" i]')
                       || document.querySelector('button[aria-label*="selector" i]');
                if (!b) return '';
                return (b.getAttribute('aria-label') || '') + '|' + (b.innerText || '');
            }""")
        except Exception:
            return ""

    async def _menu_open():
        """True if a model-menu menuitem is currently visible."""
        try:
            return await page.evaluate("""() => {
                const its = document.querySelectorAll('[role=menuitem]');
                for (const it of its) {
                    const t = (it.innerText||'');
                    if (/Pro|Flash|Extended thinking|延伸思考/.test(t) && it.offsetParent) return true;
                }
                return false;
            }""")
        except Exception:
            return False

    async def _ensure_open():
        """Open the model menu if it isn't already open. Returns True if a
        picker button was found."""
        if await _menu_open():
            return True
        b = await _pick(page, MODEL_BTN)
        if not b:
            return False
        try:
            await b.click(); await asyncio.sleep(1.5)
        except Exception:
            pass
        return True

    model_map = {
        "flash-lite": ["3.1 Flash-Lite", "Flash-Lite"],
        "flash": ["3.5 Flash", "Flash"],
        "pro": ["3.1 Pro", "Pro"],
        "pro-latest": ["3.1 Pro", "Pro"],
    }
    base_label = model_map.get((model or "pro").lower(), [model])[0] if model else None
    want_ext = bool(thinking) and thinking.lower() in ("extended", "extend")

    # Select base model, then (optionally) Extended thinking. Google's menu
    # closes after each selection, so we re-open before each click. Verify the
    # picker label reflects the choice; retry (up to 4×) if not confirmed.
    for attempt in range(4):
        if not await _ensure_open():
            _log("model selector not found"); break
        if base_label:
            hit = await _click_menuitem(page, [base_label] + model_map.get((model or "pro").lower(), [model]))
            if hit:
                _log(f"base model: {hit}")
        await asyncio.sleep(1.0)
        if want_ext:
            if not await _ensure_open():
                _log("model selector not found for extended"); break
            hit = await _click_menuitem(page, ["延伸思考", "Extended thinking"])
            if hit:
                _log("extended thinking: ON")
            else:
                _log("extended thinking menuitem not found")
            await asyncio.sleep(1.0)
        label = await _picker_label()
        has_base = (not base_label) or (base_label.split()[-1] in label)  # "Pro"/"Flash"/"Lite"
        has_ext = (not want_ext) or ("Extended" in label)
        if has_base and has_ext:
            break
        _log(f"model not confirmed (attempt {attempt+1}): label='{label[:60]}' — retrying")
    _log(f"model label final: {(await _picker_label())[:80]}")
    try:
        await page.keyboard.press("Escape"); await asyncio.sleep(0.5)
    except Exception:
        pass


