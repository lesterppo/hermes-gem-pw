            elif args[i] == "-t" and i+1 < len(args): timeout = int(args[i+1]); i += 2
            elif args[i] in ("-q", "--quiet", "--json", "--json-out"): i += 1
            elif args[i] == "--brief": brief = True; i += 1
            elif args[i] == "--new": cf = None; i += 1
            elif args[i].startswith("-"): i += 1
            else: pp.append(args[i]); i += 1
        p = " ".join(pp).strip()
        if not p: _emit(_err("NO_PROMPT", "No prompt provided")); sys.exit(1)
        _emit(await _retry_once(lambda: cmd_chat(gid, p, conv_file=cf, model=model, thinking=thinking, brief=brief, output_path=out, timeout=timeout, cdp=cdp_mode)))


