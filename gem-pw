    pw, ctx, page = await _launch(cdp=cdp)
    try:
        # SAFETY (ported from gem.py): require exactly one signed-in account.
        # A wrong/extra account silently downgrades Pro → Flash in Gemini.
        # Check on /gems/view — the account email reliably appears there
        # (the create page itself does not surface it in the DOM).
        await page.goto("https://gemini.google.com/gems/view", wait_until="domcontentloaded", timeout=30000)
        await asyncio.sleep(4)
        accts = await _check_accounts(page)
        _log(f"accounts visible: {accts}")
        if len(accts) > 1:
            # Clear danger: multiple signed-in accounts → silent Pro→Flash
            # downgrade risk. Refuse until the wrong one is logged out.
            return _err("MULTI_ACCOUNT",
                        f"expected exactly 1 gmail account, got {len(accts)} "
                        f"({accts}). Log out the wrong one before creating a Gem.",
                        accounts=accts)
        if len(accts) == 0:
            # Detection is unreliable (email not always in DOM). Warn, don't block.
            _log("WARNING: could not detect account email — continuing (verify Pro is active)")
        _log("create: navigating to gems/create...")
        await page.goto("https://gemini.google.com/gems/create", wait_until="domcontentloaded", timeout=30000)
