        resp, elapsed = await _wait_response(page)
        if not resp.strip(): return _err("EMPTY", "No response")
        return _save(resp, prompt, elapsed, gem_id=gem_id, output_path=out_path)
    finally:
        await _close_session(pw, ctx, page)


# ─═════════════ COLLAB (diff protocol) ══════════════
# Token-efficient collaboration: upload the CURRENT artifact as context, then
# ask the Gem for a SURGICAL delta (unified diff) instead of re-emitting the
# entire file. The agent applies the returned diff locally (apply_gem_diff.py).
# This cuts later-round output ~10x versus full-file round-trips.
async def cmd_collab(gem_id, file_paths, instruction, out_path=None, timeout=180,
                   model=None, thinking=None, cdp=None):
    if isinstance(file_paths, str): file_paths = [file_paths]
    missing = [fp for fp in file_paths if not Path(fp).exists()]
    if missing: return _err("FILE_NOT_FOUND", ", ".join(missing))

    pw, ctx, page = await _launch(cdp=cdp)
    try:
        _log(f"collab: upload {[Path(fp).name for fp in file_paths]}")
        await page.goto(f"https://gemini.google.com/gem/{gem_id}", wait_until="domcontentloaded", timeout=30000)
        await asyncio.sleep(5)

        body = await page.inner_text("body")
        err = _check_page(body)
        if err: return _err(err, body[:200])

        tools = await _pick(page, [
            '[aria-label="上載同工具"]',
            '[aria-label*="Upload" i][aria-label*="tools" i]',
            '[aria-label*="Upload & tools" i]',
        ])
        if tools: await tools.click(); await asyncio.sleep(2)

        await page.evaluate("""() => {
            const items = document.querySelectorAll('toolbox-drawer-item, [role="menuitem"]');
            for (const item of items) {
                if (((item.innerText||'').trim().startsWith('上載檔案')) || ((item.innerText||'').trim().startsWith('Upload file'))) { item.click(); return; }
            }
        }""")
        await asyncio.sleep(2)

        # Same drawer-animation guard as cmd_upload: retry the menuitem click
        # once on timeout, else return NO_UPLOAD (retryable).
        fi = None
        try:
            fi = await page.wait_for_selector('input[type="file"]', state='attached', timeout=5000)
        except Exception:
            _log("file input not ready; re-clicking Upload-file menuitem")
            try:
                await page.evaluate("""() => {
                    const items = document.querySelectorAll('toolbox-drawer-item, [role="menuitem"]');
                    for (const item of items) {
                        if (((item.innerText||'').trim().startsWith('上載檔案')) || ((item.innerText||'').trim().startsWith('Upload file'))) { item.click(); return; }
                    }
                }""")
                await asyncio.sleep(2)
                fi = await page.wait_for_selector('input[type="file"]', state='attached', timeout=5000)
            except Exception:
                fi = None
        if not fi: return _err("NO_UPLOAD", "File input not found")
        await fi.set_input_files(file_paths)
        await asyncio.sleep(3)

        # Request a surgical diff, NOT the whole file. This is the core
        # token-saving instruction. The prompt is strict: the Gem must use the
        # REAL filename (so patch -p0 can apply), must include the actual
        # changed lines (never an empty diff), and must not wrap the diff in
        # prose that apply_gem_diff.py would choke on.
        fname = Path(file_paths[0]).name
        prompt = (
            "CONTEXT: the attached file '" + fname + "' is the current version of an artifact "
            "I am building with you.\\n"
            "TASK: " + instruction + "\\n"
            "Respond with ONLY a minimal change set. Rules —violating any makes your answer unusable:\\n"
            "1) Output a unified diff in 'diff -u' format. The header MUST be:\\n"
            "     --- a/" + fname + "\\n"
            "     +++ b/" + fname + "\\n"
            "   (the EXACT filename '" + fname + "', not 'file.py' or a placeholder). Show the real "
            "lines you changed with 2-3 lines of unchanged context above/below so `patch -p0` applies it.\\n"
            "2) The diff MUST contain at least one real added or removed line (a '+' or '-' line that is "
            "not a header). An empty or context-only diff is a FAILURE — include the actual code.\\n"
            "3) If you must add entirely new functions/blocks, ALSO output them in a fenced ```newcode block.\\n"
            "4) Do NOT restate the whole file. Do NOT add any commentary, explanation, or markdown outside "
            "the diff / ```newcode blocks. Your entire answer is the change set."
        )
        if model or thinking:
            # Only forward an explicit override; otherwise the Gem's persisted
            # default (Pro+Extended) is used. Avoids the silent Flash downgrade.
            override = []
            if model: override.append(f"model={model}")
            if thinking: override.append(f"thinking={thinking}")
            prompt += "\n(OVERRIDE ONLY IF EXPLICITLY REQUESTED: " + ", ".join(override) + ".)"
        if not await _type_and_submit(page, prompt): return _err("NO_INPUT", "Chat input not found")
        _log("waiting...")
        resp, elapsed = await _wait_response(page, timeout=timeout)
        if not resp.strip(): return _err("EMPTY", "No response")
        return _save(resp, prompt, elapsed, gem_id=gem_id, output_path=out_path)
    finally:
        await _close_session(pw, ctx, page)




async def cmd_image(gem_id, description, cdp=None):
    pw, ctx, page = await _launch(cdp=cdp)
    try:
        _log(f"image: {gem_id}")
        await page.goto(f"https://gemini.google.com/gem/{gem_id}", wait_until="domcontentloaded", timeout=30000)
        await asyncio.sleep(5)

        tools = await _pick(page, [
            '[aria-label="上載同工具"]',
            '[aria-label*="Upload" i][aria-label*="tools" i]',
            '[aria-label*="Upload & tools" i]',
        ])
        if tools: await tools.click(); await asyncio.sleep(2)

        clicked = await page.evaluate("""() => {
            const items = document.querySelectorAll('toolbox-drawer-item');
            for (const item of items) {
                if (((item.innerText||'').trim().startsWith('製作圖像')) || ((item.innerText||'').trim().startsWith('Create image'))) {
                    item.click(); return 'ok';
                }
            }
            return 'not-found';
        }""")
        _log(f"img btn: {clicked}")
        await asyncio.sleep(3)

        if clicked == 'ok':
            if not await _type_and_submit(page, description):
                return _err("NO_INPUT", "Chat input not found")
        else:
            if not await _type_and_submit(page, f"Generate an image: {description}"):
                return _err("NO_INPUT", "Chat input not found")

        _log("generating...")
        resp, elapsed = await _wait_response(page, timeout=60)
        if "Creating" in resp or "建立" in resp:
            _log("image still creating, waiting for render...")
            for _ in range(20):
                await asyncio.sleep(3)
                has_img = await page.evaluate("""() => {
                    return document.querySelectorAll('.response-content img[src], message-content img[src]').length;
                }""")
                if has_img > 0:
                    await asyncio.sleep(2)
                    break
            try:
                t = await page.evaluate("""() => {
                    const msgs = document.querySelectorAll('.response-content, message-content');
                    return msgs.length ? msgs[msgs.length-1].innerText : '';
                }""")
                if t: resp = t
            except: pass

        images = []
        try:
            img_els = await page.query_selector_all('.response-content img, message-content img')
            for idx, img_el in enumerate(img_els):
                try:
                    fname = OUTPUT_DIR / f"gem-img-{int(time.time())}-{idx}.png"
                    await img_el.screenshot(path=str(fname))
                    images.append(str(fname))
                    _log(f"image: {fname.name}")
                except Exception as e:
                    _log(f"img screenshot err: {e}")
        except Exception as e:
            _log(f"img err: {e}")

        r = {"ok": True, "t": round(elapsed, 1)}
        if resp.strip():
            r["s"] = len(resp)
            f = OUTPUT_DIR / f"gem-pw-{int(time.time())}.md"
            f.write_text(resp, encoding="utf-8"); r["f"] = str(f)
        if images: r["images"] = images
        if not resp.strip() and not images: r = _err("EMPTY", "No image generated")
        return r
    finally:
        await _close_session(pw, ctx, page)


