        if not saved:
            return _err("SAVE_FAILED", f"Gem not saved: {detail}")
        if saved:
            await asyncio.sleep(6)
            for _ in range(10):
                for pg in ctx.pages:
                    m = re.search(r'/gem/([a-zA-Z0-9_-]+)', pg.url or "")
                    if m:
                        gem_id = m.group(1)
