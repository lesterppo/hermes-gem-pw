async def main():
    global QUIET, JSON_OUT, CDP_URL
    args = sys.argv[1:]
    if not args or args[0] in ("--help", "-h", "help"):
        print(json.dumps({"ok": True, "help": "gem-pw v4 — Self-contained Gemini Gem CLI (locale-agnostic: zh-TW + English)",
            "commands": {
                "chat": "gem-pw <id> \"prompt\" [-c sess.json] [-m model] [--thinking extended] [-o out.md] [-t seconds] [--brief] [--new] [--json-out] [-q]",
                "create": "gem-pw --create \"Name\" \"Instructions\" [--knowledge-file <f>] [--knowledge-code <url>] [--knowledge-photo <img>] [--knowledge-folder <dir>] [-m model] [--thinking extended]",
                "edit": "gem-pw --edit <id> [--name <n>] [--instructions <text>] [--knowledge-file <f>] [--knowledge-code <url>] [--knowledge-photo <img>] [--knowledge-folder <dir>] [-m model] [--thinking extended]",
                "delete": "gem-pw --delete <id>",
                "upload": "gem-pw --upload <id> -f <file> \"question\"",
                "collab": "gem-pw --collab <id> -f <current-file> \"instruction\" [-o out.md] [-t sec] [-m model] [--thinking extended]",
                "image": "gem-pw --img <id> \"description\"",
                "flags": "[--cdp [url]] use running headed Chromium page server (9223) if alive; [--no-cdp] force own headed browser; [--json-out] compact JSON; [-q] quiet"
            }}))
        sys.exit(0)

    if "-q" in args or "--quiet" in args: QUIET = True
    if "--json-out" in args: JSON_OUT = True

    # CDP mode: prefer connecting to a running headed Chromium page server
    # (e.g. hermes_cdp_server.py on 9223) for reliability + token savings;
    # fall back to launching our own headed Chromium when CDP is unavailable.
    #   --cdp [url]  force CDP (optional URL, else GEM_PW_CDP / 127.0.0.1:9223)
    #   --no-cdp     force own headed browser (no CDP)
    #   (neither)    auto: use CDP if the server is alive, else headed
    forced_cdp = None
    if "--no-cdp" in args:
        forced_cdp = False
        CDP_URL = ""  # disable auto too
    ci = None
    for i, a in enumerate(args):
        if a == "--cdp":
            forced_cdp = True
            if i + 1 < len(args) and not args[i+1].startswith("-"):
                CDP_URL = args[i+1]
            break
    cdp_mode = forced_cdp if forced_cdp is not None else (CDP_URL if CDP_URL else None)

    # Single-instance guard: one headed Chromium profile. Fail fast if another
    # gem-pw is already driving it (concurrent runs collide -> empty responses).
    if not _acquire_lock():
        _emit({"ok": False, "err": "LOCKED",
               "msg": "another gem-pw process holds the Chromium profile lock "
                      f"({_LOCK_PATH}). Run one gem-pw at a time."})
        sys.exit(1)

    if args[0] == "--create":
        kf = []; kc = None; kp = []; kdir = []; model = None; thinking = None
        name = None; inst = None; i = 1
        while i < len(args):
            if args[i] == "--knowledge-file" and i+1 < len(args): kf.append(args[i+1]); i += 2
            elif args[i] == "--knowledge-code" and i+1 < len(args): kc = args[i+1]; i += 2
            elif args[i] == "--knowledge-photo" and i+1 < len(args): kp.append(args[i+1]); i += 2
            elif args[i] == "--knowledge-folder" and i+1 < len(args): kdir.append(args[i+1]); i += 2
            elif args[i] == "-m" and i+1 < len(args): model = args[i+1]; i += 2
            elif args[i] == "--thinking" and i+1 < len(args): thinking = args[i+1]; i += 2
            elif args[i].startswith("-"): i += 1
            elif not name: name = args[i]; i += 1
            elif not inst: inst = args[i]; i += 1
            else: i += 1
        if not name or not inst:
            _emit(_err("USAGE", "--create <name> <instructions> [--knowledge-file <f>] [--knowledge-code <url>] [--knowledge-photo <img>] [--knowledge-folder <dir>] [-m <model>] [--thinking extended]"))
            sys.exit(1)
        _emit(await _retry_once(lambda: cmd_create(name, inst, knowledge_files=kf or None,
                                          knowledge_code=kc, knowledge_photos=kp or None,
                                          knowledge_folders=kdir or None,
                                          model=model, thinking=thinking, cdp=cdp_mode)))
    elif args[0] == "--edit":
        if len(args) < 2: _emit(_err("USAGE", "--edit <gem-id> [--name <n>] [--instructions <text>] [--knowledge-file <f>] [--knowledge-code <url>] [--knowledge-photo <img>] [--knowledge-folder <dir>] [-m <model>] [--thinking extended]")); sys.exit(1)
        gid = args[1]
        kf = []; kc = None; kp = []; kdir = []; model = None; thinking = None
        name = None; inst = None; i = 2
        while i < len(args):
            if args[i] == "--name" and i+1 < len(args): name = args[i+1]; i += 2
            elif args[i] == "--instructions" and i+1 < len(args): inst = args[i+1]; i += 2
            elif args[i] == "--knowledge-file" and i+1 < len(args): kf.append(args[i+1]); i += 2
            elif args[i] == "--knowledge-code" and i+1 < len(args): kc = args[i+1]; i += 2
            elif args[i] == "--knowledge-photo" and i+1 < len(args): kp.append(args[i+1]); i += 2
            elif args[i] == "--knowledge-folder" and i+1 < len(args): kdir.append(args[i+1]); i += 2
            elif args[i] == "-m" and i+1 < len(args): model = args[i+1]; i += 2
            elif args[i] == "--thinking" and i+1 < len(args): thinking = args[i+1]; i += 2
            elif args[i].startswith("-"): i += 1
            else: i += 1
        _emit(await _retry_once(lambda: cmd_edit(gid, name=name, instructions=inst,
                                        knowledge_files=kf or None,
                                        knowledge_code=kc, knowledge_photos=kp or None,
                                        knowledge_folders=kdir or None,
                                        model=model, thinking=thinking, cdp=cdp_mode)))
    elif args[0] == "--delete":
        if len(args) < 2: _emit(_err("USAGE", "--delete <gem-id>")); sys.exit(1)
        _emit(await cmd_delete(args[1], cdp=cdp_mode))
    elif args[0] == "--upload":
        fps = []; pp = []; i = 2; gid = args[1]; out = None
        while i < len(args):
            if args[i] == "-f" and i+1 < len(args): fps.append(args[i+1]); i += 2
            elif args[i] == "-o" and i+1 < len(args): out = args[i+1]; i += 2
            elif args[i].startswith("-"): i += 1
            else: pp.append(args[i]); i += 1
        p = " ".join(pp)
        if not fps or not p: _emit(_err("USAGE", "--upload <id> -f <file1> [-f <file2> ...] <question>")); sys.exit(1)
        _emit(await _retry_once(lambda: cmd_upload(gid, fps, p, out_path=out, cdp=cdp_mode)))
    elif args[0] == "--img":
        if len(args) < 3: _emit(_err("USAGE", "--img <gem-id> <description>")); sys.exit(1)
        _emit(await cmd_image(args[1], args[2], cdp=cdp_mode))
    elif args[0] == "--collab":
        # gem-pw --collab <id> -f <current-file> "instruction" [-o out.md] [-t sec] [-m model] [--thinking extended]
        fps = []; out = None; timeout = 180; model = None; thinking = None; i = 2; gid = args[1]; pp = []
        while i < len(args):
            if args[i] == "-f" and i+1 < len(args): fps.append(args[i+1]); i += 2
            elif args[i] == "-o" and i+1 < len(args): out = args[i+1]; i += 2
            elif args[i] == "-t" and i+1 < len(args): timeout = int(args[i+1]); i += 2
            elif args[i] == "-m" and i+1 < len(args): model = args[i+1]; i += 2
            elif args[i] == "--thinking" and i+1 < len(args): thinking = args[i+1]; i += 2
            elif args[i].startswith("-"): i += 1
            else: pp.append(args[i]); i += 1
        instr = " ".join(pp)
        if not fps or not instr: _emit(_err("USAGE", "--collab <id> -f <current-file> \"instruction\"")); sys.exit(1)
        # Note: -m/--thinking are parsed but intentionally NOT passed to the Gem
        # unless set — the Gem's persisted default (Pro+Extended) is preferred
        # per the "never pass -m at chat time" rule. Passed only if the user
        # explicitly overrides.
        _emit(await _retry_once(lambda: cmd_collab(gid, fps, instr, out_path=out, timeout=timeout, model=model, thinking=thinking, cdp=cdp_mode)))
    else:
        try:
            m = re.search(r'gemini\.google\.com/gem/([a-zA-Z0-9_-]+)', args[0])
            gid = m.group(1) if m else (args[0] if '/' not in args[0] else args[0])
        except:
            _emit(_err("BAD_URL", "Invalid Gem ID or URL. Use gem-pw --help for usage."))
            sys.exit(1)
        cf = None; model = None; thinking = None; brief = False; out = None; timeout = 120; pp = []; i = 1
        while i < len(args):
            if args[i] == "-c" and i+1 < len(args): cf = args[i+1]; i += 2
